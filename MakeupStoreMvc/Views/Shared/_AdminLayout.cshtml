<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Aura Yönetim Paneli</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>

@{
    var currentUrl = Context.Request.Path.ToString();
}

<body>
    <div class="d-flex">

        <!-- Premium Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <span class="sidebar-logo-icon">✨</span>
                <h3 class="sidebar-logo-text">Aura Admin</h3>
            </div>

            <ul class="sidebar-nav">
                <li class="nav-item">
                    <a href="/Admin/Index" class="nav-link @(currentUrl.StartsWith("/Admin", StringComparison.OrdinalIgnoreCase) || currentUrl == "/" ? "active" : "")">
                        <span class="nav-icon">📊</span>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Categories" class="nav-link @(currentUrl.StartsWith("/Categories", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                        <span class="nav-icon">🗂️</span>
                        <span class="nav-text">Kategoriler</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Brands" class="nav-link @(currentUrl.StartsWith("/Brands", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                        <span class="nav-icon">🏷️</span>
                        <span class="nav-text">Markalar</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Products" class="nav-link @(currentUrl.StartsWith("/Products", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                        <span class="nav-icon">💄</span>
                        <span class="nav-text">Ürünler</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Users" class="nav-link @(currentUrl.StartsWith("/Users", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                        <span class="nav-icon">👥</span>
                        <span class="nav-text">Kullanıcılar</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <a href="/Home/Index" class="btn-website">
                    <span>Siteye Git</span>
                    <span class="arrow">→</span>
                </a>
            </div>
        </aside>

        <!-- Main Content Wrapper -->
        <div class="main-content flex-grow-1">
            <header class="topbar">
                <div class="topbar-title">@ViewData["Title"]</div>
                
                <div class="topbar-profile">
                    <span class="profile-name">Yönetici Paneli</span>
                    <span class="profile-avatar">🌸</span>
                </div>
            </header>

            <main class="content-area">
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
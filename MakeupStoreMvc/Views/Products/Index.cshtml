@{
    Layout = "_AdminLayout";
}
@model List<MakeupStoreMvc.Models.ProductListDto>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Ürün Listesi</h2>
        <a href="/Products/Create" class="btn btn-primary">Ürün Ekle</a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Resim</th>
                <th>Ürün Adı</th>
                <th>Fiyat</th>
                <th>Stok</th>
                <th>Kategori</th>
                <th>Marka</th>
                <th>Güncelle</th>
                <th>Sil</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>

                    <td>
                        <img src="@item.ImageUrl"
                             width="70"
                             height="70"
                             style="object-fit:cover;" />
                    </td>

                    <td>@item.ProductName</td>
                    <td>@item.Price ₺</td>
                    <td>@item.Stock</td>
                    <td>@item.CategoryName</td>
                    <td>@item.BrandName</td>

                    <td>
                        <a href="/Products/Edit/@item.Id" class="btn btn-warning btn-sm">
                            Güncelle
                        </a>
                    </td>

                    <td>
                        <a href="/Products/Delete/@item.Id" class="btn btn-danger btn-sm">
                            Sil
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>